# ---- Database ----
# Async SQLAlchemy URL. Driver: asyncpg
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/crosswave

# ---- Auth (JWT) ----
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- YouTube Data API v3 ----
# API key from Google Cloud Console (no OAuth required for public channel/video data)
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# ---- App ----
APP_ENV=development
